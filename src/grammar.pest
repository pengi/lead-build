WHITESPACE = _{ " " | "\t" | "\n" }
entry = _{ SOI ~ expr ~ EOI }

expr = { expr_object | const_int | const_float }

expr_object = { "{" ~ (assignment ~ ";")* ~ "}" }

assignment = { ident ~ "=" ~ expr }


ident = { 'a'..'z' ~ ('a'..'z' | '0'..'9' | "_")* }
const_float = @{ const_int ~ ("." ~ ASCII_DIGIT*)? ~ (^"e" ~ const_int)? }
const_int = { ("+" | "-")? ~ ASCII_DIGIT+ }
